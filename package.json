{
  "name": "ameco-spot-planner-ops",
  "private": true,
  "version": "1.0.0",
  "description": "Scripts de operación (backup y restauración de RTDB) para AMECO Spot Planner. No es el frontend, que sigue siendo index.html estático.",
  "type": "module",
  "scripts": {
    "backup": "node scripts/backup-rtdb.mjs",
    "restore": "node scripts/restore-rtdb.mjs",
    "drill": "node scripts/restore-drill.mjs",
    "drill:emulator": "firebase emulators:exec --project demo-ameco-spot-planificacion --only database --non-interactive \"node scripts/restore-drill.mjs\"",
    "migrate:workers": "node scripts/migrate-workers-node.mjs",
    "test:rules": "node scripts/test-rules-workers.mjs",
    "test:rules:emulator": "firebase emulators:exec --project demo-ameco-spot-planificacion --only database --non-interactive \"node scripts/test-rules-workers.mjs\""
  },
  "dependencies": {
    "firebase-admin": "^12.6.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.4",
    "firebase-tools": "^13.29.0"
  }
}
