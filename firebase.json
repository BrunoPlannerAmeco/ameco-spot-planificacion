{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "database.rules.json",
      "database.rules.recovery.json",
      "storage.rules",
      "README.md",
      "CHANGELOG.md",
      "package.json",
      "package-lock.json",
      "node_modules/**",
      "scripts/**",
      "backups/**",
      ".github/**",
      "docs/**",
      "**/.*"
    ]
  },
  "database": {
    "rules": "database.rules.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "database": {
      "port": 9000
    },
    "storage": {
      "port": 9199
    },
    "ui": {
      "enabled": false
    }
  }
}